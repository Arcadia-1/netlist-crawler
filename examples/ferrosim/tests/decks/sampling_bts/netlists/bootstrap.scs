// Shared bootstrap definitions for sampling linearity references.
// Includes the Maestro ideal relay+vcvs bootstrap, the Maestro transistor
// bootstrap, and the older SAR bootstrap kept for bottom-plate comparison.

subckt LB_BOOTSTRAPPER_IDEAL GATE GND SH VDD VIN
    W_RESET (GATE GND VDD SH) relay vt1=0 vt2=900m ropen=10T rclosed=10
    W_TRACK (NET3 GATE SH GND) relay vt1=0 vt2=900m ropen=10T rclosed=10
    E_VIN   (NET1 GND VIN GND) vcvs gain=1.0
    E_BOOST (NET3 NET1 VDD GND) vcvs gain=1.0
ends LB_BOOTSTRAPPER_IDEAL

subckt LB_BOOTSTRAPPER_REAL GATE GND SH VDD VIN
    M7 (GATE VDD net2 GND) nch_ulvt_mac l=30n w=2u multi=1 nf=4 sd=100n \
        ad=1e-13 as=1.25e-13 pd=2.4u ps=3.5u nrd=0.248269 nrs=0.248269 \
        sa=179.203n sb=179.203n sa1=118.069n sa2=174.76n sa3=310.76n \
        sa4=171.966n sb1=118.069n sb2=174.76n sb3=310.76n spa=100n \
        spa1=100n spa2=100n spa3=100n sap=120.952n sapb=140.537n \
        spba=115.715n spba1=117.043n dfm_flag=0 spmt=1.11111e+15 spomt=0 \
        spomt1=1.11111e+60 spmb=1.11111e+15 spomb=0 spomb1=1.11111e+60
