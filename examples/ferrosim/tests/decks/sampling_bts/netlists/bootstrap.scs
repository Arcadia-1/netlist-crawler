subckt LB_SAR_BTS CLK VBST VDD VIN VSS

    M_INVCLKN_P  (CLKN CLK  VDD VDD) pch_ulvt_mac l=30n w=2u multi=1 nf=4
    M_INVCLKN_N  (CLKN CLK  VSS VSS) nch_ulvt_mac l=30n w=2u multi=1 nf=4
    M_INVCLKP_P  (CLKP CLKN VDD VDD) pch_mac      l=30n w=1u multi=1 nf=2
    M_INVCLKP_N  (CLKP CLKN VSS VSS) nch_ulvt_mac l=30n w=4u multi=1 nf=8

    C_BOOT (CBOOT_TOP CBOOT_BOT) cfmom_2t nr=80 lr=5u w=50n s=50n stm=2 spm=6 multi=1

    M_DCHG_CBOOT_BOT     (CBOOT_BOT CLKN VSS VSS) nch_mac       l=30n w=1u multi=1 nf=2
    M_PCHG_CBOOST_GATE   (CBOOST_GATE CLKP VDD VDD) pch_mac     l=30n w=1u multi=1 nf=2
    M_LIM_CBOOT_TOP      (VDD VBST CBOOT_TOP CBOOT_TOP) pch_mac l=30n w=1u multi=1 nf=2

    M_VBST_PREBOOST      (VDD CLK VBST VSS) nch_mac l=30n w=2u multi=1 nf=4
    M_CBOOST_GATE_TRACK  (CBOOST_GATE CLKP CBOOT_BOT VSS) nch_mac l=30n w=1u multi=1 nf=2
    M_BOOST_PASS         (VBST CBOOST_GATE CBOOT_TOP CBOOT_TOP) pch_ulvt_mac l=30n w=4u multi=1 nf=8
    M_PASS_VIN           (CBOOT_BOT VBST VIN VSS) nch_ulvt_mac l=30n w=4u multi=1 nf=8

    M_CASC_VBST          (VBST VDD CLKP VSS) nch_ulvt_mac l=30n w=4u multi=1 nf=8

ends LB_SAR_BTS
